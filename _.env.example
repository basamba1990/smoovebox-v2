# Configuration Supabase
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Configuration OpenAI
VITE_OPENAI_API_KEY=your_openai_api_key

# Instructions:
# 1. Copiez ce fichier vers .env
# 2. Remplacez les valeurs par vos vraies clés API
# 3. Obtenez vos clés Supabase sur https://supabase.com/dashboard
# 4. Obtenez votre clé OpenAI sur https://platform.openai.com/api-keys

